VITE_APP_TITLE=homebox-scanner
VITE_APP_BASE_PATH=/homebox-scanner/
VITE_HB_DEFAULT_BASE_URL=
VITE_HB_MOCK_MODE=false
VITE_HB_OPEN_ENTITY_URL_TEMPLATE=

# Dev proxy for local development against a real HomeBox without browser CORS pain.
# When enabled, the browser talks to localhost:5173/hb-api/* and Vite forwards to HomeBox.
VITE_HB_USE_DEV_PROXY=false
VITE_HB_DEV_PROXY_PATH=/hb-api
VITE_HB_PROXY_TARGET=
